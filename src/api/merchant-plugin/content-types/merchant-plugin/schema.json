{
  "kind": "collectionType",
  "collectionName": "merchant_plugins",
  "info": {
    "singularName": "merchant-plugin",
    "pluralName": "merchant-plugins",
    "displayName": "Merchant Plugin",
    "description": "Plugins installed by merchants"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "merchant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::merchant.merchant"
    },
    "plugin": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::plugin.plugin",
      "inversedBy": "merchantPlugins"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "config": {
      "type": "json"
    }
  }
}
