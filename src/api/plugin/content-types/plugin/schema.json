{
  "kind": "collectionType",
  "collectionName": "plugins",
  "info": {
    "singularName": "plugin",
    "pluralName": "plugins",
    "displayName": "Plugin",
    "description": "Available plugins for merchants"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": ["shopify", "woocommerce", "custom", "api", "dashboard"],
      "required": true
    },
    "version": {
      "type": "string",
      "default": "1.0.0",
      "maxLength": 20
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "inactive", "deprecated"],
      "default": "active"
    },
    "downloadUrl": {
      "type": "string",
      "maxLength": 500
    },
    "documentationUrl": {
      "type": "string",
      "maxLength": 500
    },
    "manifest": {
      "type": "json"
    },
    "merchantPlugins": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::merchant-plugin.merchant-plugin",
      "mappedBy": "plugin"
    }
  }
}
