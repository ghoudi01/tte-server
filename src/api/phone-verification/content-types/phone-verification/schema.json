{
  "kind": "collectionType",
  "collectionName": "phone_verifications",
  "info": {
    "singularName": "phone-verification",
    "pluralName": "phone-verifications",
    "displayName": "Phone Verification",
    "description": "Phone number verification records with trust scoring"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "phoneNumber": {
      "type": "string",
      "required": true,
      "maxLength": 20,
      "unique": true
    },
    "otp": {
      "type": "string",
      "maxLength": 6
    },
    "isVerified": {
      "type": "boolean",
      "default": false
    },
    "trustScore": {
      "type": "integer",
      "default": 50,
      "min": 0,
      "max": 100
    },
    "rtoCount": {
      "type": "integer",
      "default": 0
    },
    "successfulOrders": {
      "type": "integer",
      "default": 0
    },
    "lastVerifiedAt": {
      "type": "datetime"
    },
    "verificationHistory": {
      "type": "json"
    },
    "isSpam": {
      "type": "boolean",
      "default": false
    },
    "spamReason": {
      "type": "string"
    }
  }
}
