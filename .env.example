# Server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=

# App keys (comma-separated; generate with: openssl rand -base64 32)
APP_KEYS=key1,key2

# API token salt
API_TOKEN_SALT=your-api-token-salt

# Admin JWT
ADMIN_JWT_SECRET=your-admin-jwt-secret

# Transfer token (for data transfer)
TRANSFER_TOKEN_SALT=your-transfer-token-salt

# Encryption key (Strapi 5)
ENCRYPTION_KEY=your-encryption-key

# JWT secret (users-permissions plugin)
JWT_SECRET=your-jwt-secret

# Database (SQLite by default; use mysql for production per PLUGINS_DB_AND_API_SPEC)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Optional: MySQL (production)
# DATABASE_CLIENT=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_NAME=tte
# DATABASE_USERNAME=tte
# DATABASE_PASSWORD=your-password
