# Server
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=

# CORS — defaults include http://localhost:5173, https://tte.tn, https://www.tte.tn
# Add preview/staging origins (comma-separated, no spaces unless quoted):
# CORS_ORIGINS=https://preview.example.com,http://localhost:4173
# Emergency only (allows any Origin — avoid in production):
# CORS_ALLOW_ANY=true
# Behind Render/nginx so Express sees HTTPS / correct client IP for cookies:
# TRUST_PROXY=1
# Session cookie: production defaults to SameSite=None for cross-origin SPAs (Vercel + API on Render).
# Same-origin API+web can force lax: SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE=false (dev HTTP only; omit in production)

# App keys (comma-separated; generate with: openssl rand -base64 32)
APP_KEYS=key1,key2

# API token salt
API_TOKEN_SALT=your-api-token-salt

# Admin JWT
ADMIN_JWT_SECRET=your-admin-jwt-secret

# Transfer token (for data transfer)
TRANSFER_TOKEN_SALT=your-transfer-token-salt

# Encryption key (Strapi 5)
ENCRYPTION_KEY=your-encryption-key

# JWT secret (users-permissions plugin)
JWT_SECRET=your-jwt-secret

# --- TTE credits checkout (Flouci + D17) ---
# Browser origin (success/fail redirects after payment)
PUBLIC_URL=http://localhost:5173
# Public URL of this API (webhooks + tRPC); must match what Flouci can reach in prod
PUBLIC_API_URL=http://127.0.0.1:4000
# Flouci — https://docs.flouci.com
FLOUCI_PUBLIC_KEY=
FLOUCI_PRIVATE_KEY=
# D17 (La Poste Tunisienne) — set full create-payment URL or base + path per your contract
D17_CREATE_PAYMENT_URL=
# D17_API_BASE_URL=https://example.com
# D17_CREATE_PAYMENT_PATH=/payments
D17_API_KEY=
# Optional: require header x-d17-secret or x-webhook-secret on POST /api/webhooks/d17
D17_WEBHOOK_SECRET=
# Dev only: instant credits without PSP (do not enable in production)
ALLOW_DIRECT_CREDIT_PURCHASE=false

# Google OAuth (optional) — set both; callback: {PUBLIC_API_URL}/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Twilio SMS OTP (optional) — Tunisia E.164 (+216…)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional extra secret for SMS OTP hashes
OTP_PEPPER=

# Database (SQLite by default; use mysql for production per PLUGINS_DB_AND_API_SPEC)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Optional: MySQL (production)
# DATABASE_CLIENT=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_NAME=tte
# DATABASE_USERNAME=tte
# DATABASE_PASSWORD=your-password

# --- Meta (Facebook Page + Instagram messaging — TTE-hosted webhook + OAuth) ---
# Production: Neon PostgreSQL — server uses DATABASE_URL (see store.ts)
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
# Min 16 chars — encrypts Page access tokens at rest
META_TOKEN_ENCRYPTION_KEY=
# Optional; defaults to first APP_KEYS entry — signs OAuth state for /api/meta/page/*
META_OAUTH_STATE_SECRET=
# Callback for Page connect: {PUBLIC_API_URL}/api/meta/page/callback
# Webhook: GET/POST {PUBLIC_API_URL}/api/webhooks/meta

# --- Facebook login OAuth (separate from Meta Page OAuth above) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- SMTP Email (for verification & password-reset links) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TTE <noreply@tte.tn>
SMTP_SECURE=false

# --- Admin ---
# If not set, a random password is generated and logged on first boot
# ADMIN_PASSWORD=your-secure-password

# --- Logging ---
LOG_LEVEL=info
