{
  "name": "tte-nest-server",
  "version": "1.0.0",
  "private": true,
  "description": "Tunisia Trust Engine — NestJS backend with Prisma + tRPC compatibility",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/src/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "test:e2e": "tsx src/tests/e2e.smoke.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.8.2",
    "@trpc/server": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "superjson": "^2.2.2",
    "typescript": "^5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  }
}
