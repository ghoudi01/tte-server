generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  phone       String?
  passwordHash String?
  fullName    String
  totalPoints Int       @default(0)
  tier        String    @default("bronze")
  merchants   Merchant[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Merchant {
  id                           String   @id @default(uuid())
  userId                       String
  businessName                 String
  email                        String
  phone                        String
  city                         String?
  address                      String?
  apiKey                       String   @unique
  status                       String   @default("active")
  creditsBalance               Int      @default(0)
  autoValidationEnabled        Boolean  @default(true)
  whatsappValidationEnabled    Boolean  @default(true)
  autoShippingSelectionEnabled Boolean  @default(true)
  trustThresholdForDeposit     Int      @default(40)
  defaultShippingCompany       String   @default("Rapid-Poste")
  productTypes                 Json     @default("[]")
  user                         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders                       Order[]
  creditTransactions           CreditTransaction[]
  sentReferrals                Referral[] @relation("ReferrerMerchant")
  receivedReferrals            Referral[] @relation("ReferredMerchant")
  reports                      Report[]
  webhookSubscriptions         WebhookSubscription[]
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model Order {
  id                 Int      @id @default(autoincrement())
  merchantId         String
  userId             String?
  externalOrderId    String?
  phoneNumber        String
  clientName         String?
  orderAmount        Float
  trustScore         Int      @default(50)
  riskLevel          String   @default("medium")
  verificationStatus String   @default("pending")
  orderStatus        String   @default("placed")
  pointsEarned       Int      @default(0)
  sourcePlugin       String?
  metadata           Json?
  feedbacks          OrderFeedback[]
  merchant           Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model OrderFeedback {
  id         Int      @id @default(autoincrement())
  orderId    Int
  merchantId String
  rating     Int
  comment    String?
  category   String?
  source     String   @default("merchant")
  createdAt  DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([merchantId])
}

model SpamPhone {
  id          Int      @id @default(autoincrement())
  merchantId  String?
  orderId     Int?
  phoneNumber String
  verdict     String   @default("spam")
  reason      String?
  source      String?
  reportedAt  DateTime @default(now())

  @@index([phoneNumber, verdict])
  @@index([orderId])
}

model CreditTransaction {
  id         Int      @id @default(autoincrement())
  merchantId String
  type       String
  amount     Int
  reason     String
  metadata   Json?
  createdAt  DateTime @default(now())

  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
}

model Referral {
  id                Int      @id @default(autoincrement())
  referrerMerchantId String
  referredMerchantId String?
  referredEmail      String?
  status             String   @default("pending")
  createdAt          DateTime @default(now())

  referrerMerchant   Merchant @relation("ReferrerMerchant", fields: [referrerMerchantId], references: [id], onDelete: Cascade)
  referredMerchant   Merchant? @relation("ReferredMerchant", fields: [referredMerchantId], references: [id], onDelete: SetNull)

  @@index([referrerMerchantId, createdAt])
  @@index([referredMerchantId])
}

model Report {
  id                   Int      @id @default(autoincrement())
  merchantId           String
  clientName           String?
  phoneNumber          String
  externalOrderId      String?
  amount               Float?
  reportType           String
  status               String   @default("pending")
  trackingNumber       String?
  carrier              String?
  weight               Float?
  clientAddress        String?
  city                 String?
  orderDate            DateTime?
  productDescription   String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([phoneNumber])
  @@index([createdAt])
  @@index([status])
}

model WebhookSubscription {
  id               String   @id @default(uuid())
  merchantId       String
  eventTypes       Json
  url              String
  secret           String
  isActive         Boolean  @default(true)
  failureCount     Int      @default(0)
  lastAttemptedAt  DateTime?
  lastDeliveredAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  merchant         Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, url])
  @@index([merchantId])
  @@index([isActive])
  @@index([lastAttemptedAt])
}

model WebhookQueue {
  id         String   @id @default(uuid())
  eventId    String   @unique
  eventType  String
  merchantId String
  payload    Json
  queuedAt   DateTime @default(now())
  attempts   Int      @default(0)
  lastError  String?

  @@index([merchantId])
  @@index([queuedAt])
  @@index([attempts])
  @@index([eventType])
}

model WebhookDeliveryLog {
  id               String   @id @default(uuid())
  subscriptionId   String?
  eventId          String
  payload          Json
  responseStatus   Int?
  responseBody     String?
  errorMessage     String?
  attemptedAt      DateTime @default(now())
  succeeded        Boolean

  @@index([eventId])
  @@index([subscriptionId])
  @@index([attemptedAt])
  @@index([succeeded])
}

model WebhookSignature {
  id         String   @id @default(uuid())
  merchantId String
  provider   String
  secret     String
  token      String   @unique
  createdAt  DateTime @default(now())

  @@unique([merchantId, provider])
}

/**
 * Materialized view for phone features (refreshed by cron job)
 */
model PhoneFeature {
  phoneNumber       String   @id
  totalOrders       Int
  successfulOrders  Int
  avgTrustScore     Float
  firstSeenAt       DateTime?
  lastSeenAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now())

  @@index([phoneNumber])
}

/**
 * Materialized view for merchant features
 */
model MerchantFeature {
  merchantId    String   @id
  totalOrders   Int
  avgTrustScore Float
  fraudOrders   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  @@index([merchantId])
}

/**
 * Materialized view for city/region fraud statistics
 */
model CityFeature {
  city          String   @id
  totalOrders   Int
  fraudOrders   Int
  avgTrustScore Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now())

  @@index([city])
}

/**
 * Feature refresh job history
 */
model FeatureRefreshJob {
  id            String   @id @default(uuid())
  viewName      String
  status        String   // 'pending' | 'running' | 'completed' | 'failed'
  rowsProcessed Int
  durationMs    Int?
  error         String?
  createdAt     DateTime @default(now())
  completedAt   DateTime?

  @@index([status])
  @@index([createdAt])
}

// A/B Test Configuration
model ABTestConfig {
  id              String   @id @default(uuid())
  name            String
  description     String
  baselineVariant Json
  treatmentVariant Json
  trafficSplit    Float
  sampleSize      Int
  successMetrics  String  // comma-separated list for SQLite compatibility
  startDate       DateTime
  endDate         DateTime?
  status          String   // 'planning' | 'running' | 'completed' | 'stopped'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  results         ABTestResult[]

  @@index([status])
  @@index([name])
}

/**
 * A/B Test Results
 */
model ABTestResult {
  id                  String   @id @default(uuid())
  testId              String
  variant             String
  orderId             Int
  predictedFraud      Boolean
  actualFraud         Boolean
  processingTimeMs    Int
  revenueImpact       Float?
  customerSatisfaction Float?
  createdAt           DateTime @default(now())

  test                ABTestConfig @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variant])
  @@index([createdAt])
}
